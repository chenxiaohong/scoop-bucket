{
    "version": "4.1.9.23",
    "description": "Weixin (微信) is a free messaging and calling app.",
    "notes": "We don't persist your WeChat data, it is still stored in '%APPDATA%\\Tencent\\WeChat'.",
    "homepage": "https://pc.weixin.qq.com/",
    "license": {
        "identifier": "Proprietary",
        "url": "https://www.wechat.com/en/service_terms.html"
    },
    "architecture": {
        "64bit": {
            "url": "https://dldir1v6.qq.com/weixin/Universal/Windows/WeChatWin_4.1.9.exe#/dl.7z",
            "hash": "bb5a372f1a4622d4d9eeb738eac05f6c1a22ef528b94458bbbb292f0ec247d27"
        }
    },
    "installer": {
        "script": [
            "Expand-7zipArchive \"$dir\\install.7z\" \"$dir\" -Removal",
            "Remove-Item \"$dir\\`$*\", \"$dir\\Uninst*\" -Force -Recurse -ErrorAction SilentlyContinue",
            "$configpath = \"$env:APPDATA\\Tencent\\WeChat\\All Users\\config\"",
            "ensure \"$configpath\" | Out-Null",
            "Set-Content -NoNewline -Path \"$configpath\\3ebffe94.ini\" -Value \"$persist_dir\"",
            "$regpath = \"HKCU:Software\\Tencent\\WeChat\"",
            "if (!(Test-Path \"$regpath\")) {",
            "    New-Item -Path \"$regpath\" -Type Directory -Force | Out-Null",
            "}",
            "New-ItemProperty -Path $regpath -Name \"FileSavePath\" -Value \"$persist_dir\" -Force | Out-Null"
        ]
    },
    "shortcuts": [
        [
            "Weixin.exe",
            "微信"
        ]
    ],
    "persist": "WeChat Files",
    "uninstaller": {
        "script": [
            "Remove-Item -Path \"$env:APPDATA\\Tencent\\WeChat\\All Users\\config\\3ebffe94.ini\" -Force -ErrorAction SilentlyContinue | Out-Null",
            "Remove-ItemProperty -Path \"HKCU:Software\\Tencent\\WeChat\" -Name \"FileSavePath\" -Force -ErrorAction SilentlyContinue | Out-Null"
        ]
    },
    "checkver": {
        "script": [
            "$resp = Invoke-WebRequest -UseBasicParsing -Uri 'https://luban.m.qq.com/api/public/software-manager/softwareProxy' -Body 'cmdid=3318&jprxReq%5Breq%5D%5Bsoft_id_list%5D%5B%5D=11488' -Method 'POST'",
            "Write-Output $resp.Content"
        ],
        "jsonpath": "$.resp.soft_list[0].ver_name",
        "regex": "(?<version>(?<short>[\\d.]+)\\.\\d+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://dldir1v6.qq.com/weixin/Universal/Windows/WeChatWin_$matchShort.exe#/dl.7z"
            }
        }
    }
}
