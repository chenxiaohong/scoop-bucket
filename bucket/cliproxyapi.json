{
    "version": "7.1.67",
    "description": "OpenAI/Gemini/Claude/Codex compatible API proxy for CLI models.",
    "homepage": "https://github.com/router-for-me/CLIProxyAPI",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.1.67/CLIProxyAPI_7.1.67_windows_amd64.zip",
            "hash": "7be3de11cb951a4c10ba1c159b82925ece991c26f8cf70efb5eccb12f78c4fd1"
        },
        "arm64": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.1.67/CLIProxyAPI_7.1.67_windows_aarch64.zip",
            "hash": "8749d106657130e3417667b2ecc248a25722170aa7c64e5a93b0fd4f8638da60"
        }
    },
    "pre_install": "if (!(Test-Path \"$persist_dir\\config.yaml\")) { Copy-Item \"$dir\\config.example.yaml\" \"$dir\\config.yaml\" }",
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "-config \"$persist_dir\\config.yaml\""
        ],
        [
            "cli-proxy-api.exe",
            "cliproxyapi",
            "-config \"$persist_dir\\config.yaml\""
        ]
    ],
    "persist": [
        "config.yaml",
        "logs"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/router-for-me/CLIProxyAPI/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v$version/CLIProxyAPI_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v$version/CLIProxyAPI_$version_windows_aarch64.zip"
            }
        },
        "hash": {
            "url": "https://api.github.com/repos/router-for-me/CLIProxyAPI/releases/latest",
            "jsonpath": "$.assets[?(@.name == '$basename')].digest"
        }
    },
    "notes": [
        "The default Scoop shims use persisted config: $persist_dir\\config.yaml",
        "OAuth tokens use the app default auth-dir from config.yaml: ~/.cli-proxy-api"
    ]
}
