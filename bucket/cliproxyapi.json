{
    "version": "6.9.42",
    "description": "OpenAI/Gemini/Claude/Codex compatible API proxy for CLI models.",
    "homepage": "https://github.com/router-for-me/CLIProxyAPI",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v6.9.42/CLIProxyAPI_6.9.42_windows_amd64.zip",
            "hash": "9ef9a7fc163ffc2318de2284d8fc244a0ed5ea5ae148cd39f7a69a46de268ab4"
        },
        "arm64": {
            "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v6.9.42/CLIProxyAPI_6.9.42_windows_arm64.zip",
            "hash": "217b6c4167ffa0250d384ffedd0e89550045407ad47cef95be579f338bfee581"
        }
    },
    "pre_install": "if (!(Test-Path \"$persist_dir\\config.yaml\")) { Copy-Item \"$dir\\config.example.yaml\" \"$dir\\config.yaml\" }",
    "bin": [
        [
            "cli-proxy-api.exe",
            "cli-proxy-api",
            "-config \"$persist_dir\\config.yaml\""
        ],
        [
            "cli-proxy-api.exe",
            "cliproxyapi",
            "-config \"$persist_dir\\config.yaml\""
        ]
    ],
    "persist": [
        "config.yaml",
        "logs"
    ],
    "checkver": {
        "url": "https://api.github.com/repos/router-for-me/CLIProxyAPI/releases/latest",
        "jsonpath": "$.tag_name",
        "regex": "v([\\d.]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v$version/CLIProxyAPI_$version_windows_amd64.zip"
            },
            "arm64": {
                "url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v$version/CLIProxyAPI_$version_windows_arm64.zip"
            }
        },
        "hash": {
            "url": "https://api.github.com/repos/router-for-me/CLIProxyAPI/releases/latest",
            "jsonpath": "$.assets[?(@.name == '$basename')].digest"
        }
    },
    "notes": [
        "The default Scoop shims use persisted config: $persist_dir\\config.yaml",
        "OAuth tokens use the app default auth-dir from config.yaml: ~/.cli-proxy-api"
    ]
}
